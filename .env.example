# 放在仓库根目录，文件名为 `.env`（已在 .gitignore，勿提交密钥）
# 保存后请重启 uvicorn，后端会自动加载。

# —— DeepSeek（OpenAI 兼容）示例：V4 Pro ——
# 密钥三选一写入即可（优先级：PERSONALITY_AI_API_KEY > OPENAI_API_KEY > DEEPSEEK_API_KEY）
# DEEPSEEK_API_KEY=sk-xxxxxxxx
# 或
# OPENAI_API_KEY=sk-xxxxxxxx

# Base URL 必须含 /v1（程序请求 {BASE}/chat/completions）。
# 勿写 https://api.deepseek.com（缺 /v1 会打到错误路径）；可写：
# PERSONALITY_AI_BASE_URL=https://api.deepseek.com/v1

# 模型名以 DeepSeek 控制台 / 文档为准，例如：
# PERSONALITY_AI_MODEL=deepseek-v4-pro

# —— 其它兼容接口（可选）——
# PERSONALITY_AI_API_KEY=
# 火山方舟等写到「含 api/v3」为止，例如：
# PERSONALITY_AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
